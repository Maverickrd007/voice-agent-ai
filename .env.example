# Server configuration
PORT=3000

# Ngrok URL (for local testing - leave empty in production)
# e.g., https://<your-ngrok-id>.ngrok-free.app
SERVER_URL=

# Vapi keys (if needed for outbound calls or API interactions)
VAPI_API_KEY=your_vapi_api_key_here

# Twilio keys (for reference, usually configured directly in Vapi dashboard)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
